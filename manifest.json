{
  "manifest_version": 3,
  "name": "API Mock Master",
  "version": "1.0.0",
  "description": "Intercept and mock API responses for development and testing",
  "permissions": ["storage", "tabs", "windows"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "API Mock Master"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
